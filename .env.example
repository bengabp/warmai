# Copy to `.env` and edit before running `docker compose up`.

# ---- runtime profile ----
WARMAI_ENVIRONMENT=development        # development | staging | production
WARMAI_LOG_FORMAT=console             # console (dev) or json (prod)
WARMAI_LOG_LEVEL=INFO

# ---- secrets ----
# REQUIRED. Generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
WARMAI_SECRET_KEY=replace-me-with-a-long-random-string

# Anyone signing up must supply this code. Set to a private value.
WARMAI_SIGNUP_ACCESS_CODE=admin

# ---- mongo ----
WARMAI_MONGODB_DB=warmai
MONGO_PORT=27017

# ---- networking ----
BACKEND_PORT=8080
FRONTEND_PORT=3000

# Where the browser reaches the API. Used at build time by the frontend.
NEXT_PUBLIC_API_URL=http://localhost:8080

# JSON-encoded list of CORS origins.
WARMAI_CORS_ORIGINS=["http://localhost:3000"]

# ---- safety net ----
# When set, every warmup email goes to this address instead of the real
# recipient. Leave empty in production. Recommended in dev/staging.
WARMAI_WARMUP_RECIPIENT_OVERRIDE=
